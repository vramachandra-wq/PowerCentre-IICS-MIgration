  "sql_overrides": [
    {
      "sql_override_id": "SQL_10e31efbf3148f4f",
      "mapping_id": "AST_9373b4f41bdebd10",
      "mapping_name": "JEG_SDE_ORA_WC_PBCS_BUDGET_ACTUALS_FS",
      "context_type": "TRANSFORMATION",
      "context_name": "SQ_WC_PBCS_ACTUALS_P_FS",
      "sql_query": "select SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_actuals_MS_fs where AUDITTRAIL='Management_View'\r\n\r\nUNION ALL\r\n\r\nselect SCENARIO, concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD, LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_actuals_MS_fs where AUDITTRAIL='Statutory_View'\r\n\r\nUNION ALL\r\n\r\nselect SCENARIO, PERIOD,LEGAL_ENTITY ,PERFORMANCE_UNIT,CURRENCY,ACCOUNT,AUDITTRAIL, sum(AMOUNT) as AMOUNT \r\nFROM((select SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,'Proforma_View' as AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_actuals_MS_fs where AUDITTRAIL='Management_View') \r\nUNION ALL \r\n(select SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,'Proforma_View' as AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_actuals_p_fs )) \r\ngroup by SCENARIO,PERIOD,LEGAL_ENTITY ,PERFORMANCE_UNIT,CURRENCY,ACCOUNT,AUDITTRAIL\r\n\r\nUNION ALL \r\n\r\nselect SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_plan_MS_fs where AUDITTRAIL='Management_View'\r\n\r\nUNION ALL\r\n\r\nselect SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_plan_MS_fs where AUDITTRAIL='Statutory_View'\r\n\r\nUNION ALL\r\n\r\nselect SCENARIO,PERIOD,LEGAL_ENTITY ,PERFORMANCE_UNIT,CURRENCY,ACCOUNT,AUDITTRAIL, sum(AMOUNT) as AMOUNT \r\nFROM((select SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,'Proforma_View' as AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_plan_MS_fs where AUDITTRAIL='Management_View') \r\nUNION ALL \r\n(select SCENARIO,concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD,LEGAL_ENTITY ,substr(PERFORMANCE_UNIT,4) PERFORMANCE_UNIT,CURRENCY,(case when substr(ACCOUNT,1,3) ='AC_' THEN substr(ACCOUNT,4) ELSE ACCOUNT END) ACCOUNT,'Proforma_View' as AUDITTRAIL,to_number(substr(AMOUNT,1,(instr(AMOUNT, chr(13))-1))) as AMOUNT \r\nFROM wc_pbcs_plan_p_fs )) \r\ngroup by SCENARIO,PERIOD,LEGAL_ENTITY ,PERFORMANCE_UNIT,CURRENCY,ACCOUNT,AUDITTRAIL"
    },
    {
      "sql_override_id": "SQL_2b130079ef11e712",
      "mapping_id": "AST_9373b4f41bdebd10",
