      "context_type": "SESSION",
      "context_name": "JEG_SDE_ORA_WC_PBCS_BUDGET_ACTUALS_FS",
      "sql_query": "select * from WC_PBCS_ACTUALS_PS where PERIOD in (\r\nselect distinct PERIOD FROM(\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD  from wc_pbcs_actuals_MS_fs\r\nUNION\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD from wc_pbcs_actuals_p_fs \r\nUNION\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD  from wc_pbcs_plan_MS_fs\r\nUNION\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD  from wc_pbcs_plan_p_fs\r\n)\r\n)\r\n\r\nUNION ALL\r\n\r\nselect * from WC_PBCS_PLAN_PS where PERIOD in (\r\nselect distinct PERIOD FROM(\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD  from wc_pbcs_actuals_MS_fs\r\nUNION\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD from wc_pbcs_actuals_p_fs \r\nUNION\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD  from wc_pbcs_plan_MS_fs\r\nUNION\r\nselect concat(concat(upper(period),'-FY20'),substr(YEAR,3)) PERIOD  from wc_pbcs_plan_p_fs\r\n)\r\n)"
