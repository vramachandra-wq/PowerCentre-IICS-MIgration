  "transformations": [
    {
      "transformation_name": "SQ_WC_PBCS_BUDGET_ACTUALS_FS",
      "type": "Source Qualifier",
      "reusable": "NO",
      "attributes": {
        "Sql Query": "select  /*+ PARALLEL(WC_PBCS_BUDGET_ACTUALS_FS,9,DEFAULT) */\r\ndistinct FS.PERIOD, \r\nFS.LEGAL_ENTITY, \r\nFS.PERFORMANCE_UNIT,\r\nFS.CURRENCY,\r\nFS.ACCOUNT,\r\nFS.AUDITTRAIL,\r\nFS.PLAN AS PLAN,\r\nFS.ACTUALS as ACTUALS,\r\n0 AS BUDGET_BILL_HRS ,\r\n0 As ACTUALS_BILL_HRS ,\r\n\r\nNVL(MP.ROW_WID, 0) AS GL_PERIOD_WID,\r\nNVL(AC.ROW_WID, 0) AS GL_ACCOUNT_WID,\r\nNVL(BU.ROW_WID, 0) AS PU_WID,\r\nNVL(EX.ROW_WID, 0) AS PLAN_FX_RATE_WID,\r\n'N' AS PER_HOUR_METRIC_FLG\r\nFROM\r\n(select * from WC_PBCS_BUDGET_ACTUALS_FS\r\npivot (sum(amount) for scenario in ( 'Plan' as PLAN , 'Actual' as ACTUALS)\r\n))FS,\r\nW_MCAL_PERIOD_D MP,\r\nWC_ACCOUNT_DH AC,\r\nWC_BU_ORG_DH BU,\r\nWC_PBCS_PLAN_EX_RATE_D EX\r\n\r\nWHERE FS.PERIOD = MP.MCAL_PERIOD_NAME(+)\r\n\r\nAND FS.ACCOUNT = AC.ACCOUNT_NUM(+)\r\n\r\nAND FS.PERFORMANCE_UNIT = BU.PU(+)\r\n\r\nAND SUBSTR(FS.CURRENCY, 1, 3) = EX.CURRENCY(+)\r\nAND EX.FX_RATE_TYPE(+) = 'FX Rates - Average'\r\nAND FS.PERIOD = EX.PERIOD(+)\r\n\r\nUNION\r\n\r\nSelect * from (\r\nWITH \r\nBILL AS (\r\nselect * from (select  PERIOD, LEGAL_ENTITY, PERFORMANCE_UNIT, CURRENCY, FST.ACCOUNT, AUDITTRAIL,SCENARIO, AMOUNT \r\nfrom WC_PBCS_BUDGET_ACTUALS_BH_FS CROSS JOIN (select distinct account FROM  WC_PBCS_BUDGET_ACTUALS_PH_FS) FST ) \r\nPIVOT (SUM(AMOUNT) FOR SCENARIO IN ( 'Plan' AS PLAN , 'Actual' AS ACTUALS ))\r\n)  ,\r\nFS AS (\r\nselect * from (select  PERIOD, LEGAL_ENTITY, PERFORMANCE_UNIT, CURRENCY, ACCOUNT, AUDITTRAIL,SCENARIO, AMOUNT from WC_PBCS_BUDGET_ACTUALS_PH_FS) PIVOT (SUM(AMOUNT) FOR SCENARIO IN ( 'Plan' AS PLAN , 'Actual' AS ACTUALS ))\r\n) \r\nselect /*+ PARALLEL(WC_PBCS_BUDGET_ACTUALS_PH_FS, 9,DEFAULT)  PARALLEL(WC_PBCS_BUDGET_ACTUALS_BH_FS,9,DEFAULT)*/\r\n NVL(BILL.PERIOD,FS.PERIOD) PERIOD, \r\nNVL(BILL.LEGAL_ENTITY,FS.LEGAL_ENTITY) LEGAL_ENTITY, \r\nNVL(BILL.PERFORMANCE_UNIT,FS.PERFORMANCE_UNIT) PERFORMANCE_UNIT,\r\nNVL(BILL.CURRENCY,FS.CURRENCY) CURRENCY,\r\nNVL(BILL.ACCOUNT,FS.ACCOUNT) ACCOUNT,\r\nNVL(BILL.AUDITTRAIL,FS.AUDITTRAIL) AUDITTRAIL,\r\nNVL(FS.PLAN,0)  AS PLAN,\r\nNVL(FS.ACTUALS,0)  AS ACTUALS,\r\nNVL(BILL.PLAN,0) AS BUDGET_BILL_HRS ,\r\nNVL(BILL.ACTUALS,0) AS ACTUALS_BILL_HRS ,\r\nNVL(MP.ROW_WID, 0) AS GL_PERIOD_WID,\r\nNVL(AC.ROW_WID, 0) AS GL_ACCOUNT_WID,\r\nNVL(BU.ROW_WID, 0) AS PU_WID,\r\nNVL(EX.ROW_WID, 0) AS PLAN_FX_RATE_WID,\r\n'Y' AS PER_HOUR_METRIC_FLG\r\nfrom BILL FULL OUTER JOIN FS\r\nON  FS.PERFORMANCE_UNIT=BILL.PERFORMANCE_UNIT AND FS.ACCOUNT=BILL.ACCOUNT \r\nAND FS.AUDITTRAIL=BILL.AUDITTRAIL AND FS.PERIOD=BILL.PERIOD AND FS.CURRENCY=BILL.CURRENCY\r\nAND FS.LEGAL_ENTITY=BILL.LEGAL_ENTITY \r\nLEFT JOIN WC_ACCOUNT_DH AC ON  AC.ACCOUNT_NUM=NVL(BILL.ACCOUNT, FS.ACCOUNT)\r\nLEFT OUTER JOIN WC_BU_ORG_DH BU ON BU.PU=NVL(BILL.PERFORMANCE_UNIT, FS.PERFORMANCE_UNIT)\r\nLEFT JOIN WC_PBCS_PLAN_EX_RATE_D EX on EX.CURRENCY=NVL(SUBSTR(BILL.CURRENCY, 1, 3) ,SUBSTR(FS.CURRENCY, 1, 3) ) \r\nAND EX.FX_RATE_TYPE = 'FX Rates - Average'\r\nAND EX.PERIOD=NVL(BILL.PERIOD,Fs.PERIOD) \r\n LEFT JOIN W_MCAL_PERIOD_D MP ON  MP.MCAL_PERIOD_NAME=NVL(BILL.PERIOD,FS.PERIOD) \r\n WHERE 1=1)",
        "User Defined Join": "",
