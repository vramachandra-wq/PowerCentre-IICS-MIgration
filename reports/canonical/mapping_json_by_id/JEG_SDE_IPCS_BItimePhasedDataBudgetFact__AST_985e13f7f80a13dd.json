        "Sql Query": "SELECT\r\n    bi_timephaseddata_budget.ecosystimephasedbudgetid,\r\n    bi_timephaseddata_budget.projectnumber,\r\n    bi_timephaseddata_budget.projectperiod,\r\n    bi_timephaseddata_budget.workflowinstanceid,\r\n    bi_timephaseddata_budget.budgetheaderid,\r\n    bi_timephaseddata_budget.changeheaderid,\r\n    bi_timephaseddata_budget.costaccountfield,\r\n    bi_timephaseddata_budget.pathid,\r\n    bi_timephaseddata_budget.minorperiod,\r\n    bi_timephaseddata_budget.jacobscost,\r\n    bi_timephaseddata_budget.clientcost,\r\n    bi_timephaseddata_budget.jacobshours,\r\n    bi_timephaseddata_budget.clienthours,\r\n    bi_timephaseddata_budget.currency,\r\n\tconcat(projectnumber,'~', projectperiod, '~',minorPeriod , '~',EcoSysTimephasedBudgetId ),\r\n    bi_timephaseddata_budget.gidquantity,\r\n    bi_timephaseddata_budget..GDCName\r\nFROM\r\n    bi_timephaseddata_budget\r\nwhere  workflowinstanceid in (\r\nselect distinct workflowinstanceid\r\nfrom BI_TimephasedData_Queue)",
