    "unsupported_sql": {"score": 20, "category": "sql"},
    "oracle_curly_brace_syntax": {"score": 20, "category": "sql"},
    "sql_override_conflict": {"score": 15, "category": "sql"},
    "sql_override": {"score": 15, "category": "sql"},
    "unsupported_function": {"score": 15, "category": "sql"},
    "unsupported_database_functions": {"score": 15, "category": "sql"},
    "stored_procedure": {"score": 25, "category": "transformation"},
